name: Windows RDP

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest
    timeout-minutes: 360

    steps:
      - name: Start Setup
        run: |
          echo "Setting up RDP..."
      
      - name: Keep Alive
        run: |
          while ($true) {
            Start-Sleep -Seconds 60
          }
